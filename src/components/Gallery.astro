---
import fr from '../i18n/fr.json';
import en from '../i18n/en.json';

const { lang } = Astro.props;
const t = lang === 'en' ? en : fr;

interface GalleryItem { src: string; caption?: string; }
const items: GalleryItem[] = [
  { src: '/images/about/image_5.jpg', caption: lang === 'en' ? 'Goldsmith workshop' : 'Atelier d\'orfevrerie' },
  { src: '/images/about/image_6.jpg', caption: lang === 'en' ? 'Engraving detail' : 'Detail de gravure' },
  { src: '/images/about/image_7.jpg', caption: lang === 'en' ? 'Private collection piece' : 'Piece de la collection privee' },
  { src: '/images/about/image_8.jpg', caption: lang === 'en' ? 'Opening night' : 'Vernissage' },
];
---

<section class="gallery-section py-32 px-6 md:px-12 text-noir-orfevre relative overflow-hidden" id="gallery">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-24">
      <h2 class="gallery-h2 text-5xl md:text-7xl font-serif tracking-tighter">
        {t['savoir.text']}
      </h2>
      <p class="font-sans text-sm uppercase tracking-widest text-or-fonce mt-8 md:mt-0 max-w-xs text-right" data-text-reveal="words">
        {t['quote.text']}
      </p>
    </div>

    <div class="gallery-grid grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24">
      {items.map((item, index) => (
        <div
          class={`gallery-item relative overflow-hidden group ${index === 0 ? 'is-active' : ''} ${index % 2 !== 0 ? 'md:mt-32' : ''}`}
          data-cursor="image"
          data-cursor-label="voir"
          data-caption={item.caption}
          tabindex="0"
          role="button"
          aria-label={item.caption ?? 'Savoir-faire'}
        >
          <div class="aspect-[3/4] w-full bg-gris-pierre relative overflow-hidden">
            <img
              src={item.src}
              alt={item.caption ?? 'Savoir-faire'}
              class="object-cover w-full h-full parallax-img transition-transform duration-1000 group-hover:scale-105"
              loading="lazy"
            />
            <div class="gallery-item__veil absolute inset-0 bg-or-fonce/0 group-hover:bg-or-fonce/10 transition-colors duration-700 pointer-events-none"></div>
          </div>
          {item.caption && (
            <div class="gallery-item__caption absolute bottom-6 left-6 right-6 text-ivoire opacity-0 translate-y-2 transition-all duration-500 ease-out font-serif italic text-base md:text-lg pointer-events-none">
              {item.caption}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap-config";
  import { revealLetters } from "../lib/text-reveal";

  if (typeof window !== "undefined") {
    const setup = () => {
      const section = document.getElementById("gallery");
      if (!section || section.dataset.galleryBound === "true") return;
      section.dataset.galleryBound = "true";

      const h2 = section.querySelector<HTMLElement>(".gallery-h2");
      if (h2) {
        revealLetters(h2, { stagger: 0.025, duration: 0.7, scrollTrigger: { start: "top 80%", once: true } });
      }

      const items = section.querySelectorAll<HTMLElement>(".gallery-item");
      const images = section.querySelectorAll<HTMLImageElement>(".parallax-img");
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (items.length) {
        const covers = Array.from(items).map((item) => {
          const cover = document.createElement("div");
          cover.className = "gallery-item__reveal-cover";
          item.appendChild(cover);
          return cover;
        });

        gsap.set(items, { y: 48, opacity: 0 });
        gsap.set(images, { scale: 1.08, transformOrigin: "center" });

        if (reduced) {
          gsap.set(items, { y: 0, opacity: 1 });
          gsap.set(images, { scale: 1 });
          covers.forEach((cover) => cover.remove());
        } else {
          const tl = gsap.timeline({
            scrollTrigger: {
              trigger: section.querySelector(".gallery-grid") ?? section,
              start: "top 78%",
              once: true,
            },
          });

          tl.to(items, {
            y: 0,
            opacity: 1,
            duration: 0.9,
            stagger: 0.16,
            ease: "power3.out",
          })
          .to(covers, {
            clipPath: "polygon(100% 0%, 100% 0%, 100% 100%, 100% 100%)",
            duration: 1.2,
            stagger: 0.16,
            ease: "expo.out",
            onComplete: () => covers.forEach((cover) => cover.remove()),
          }, "<")
          .to(images, {
            scale: 1,
            duration: 1.6,
            stagger: 0.16,
            ease: "power2.out",
          }, "<");
        }
      }

      section.querySelectorAll<HTMLImageElement>(".parallax-img").forEach((img) => {
        if (!img.parentElement) return;
        gsap.fromTo(img,
          { y: -30 },
          {
            y: 30,
            ease: "none",
            scrollTrigger: {
              trigger: img.parentElement,
              start: "top bottom",
              end: "bottom top",
              scrub: true,
            },
          }
        );
      });

      const activateItem = (active: HTMLElement) => {
        items.forEach((item) => item.classList.toggle("is-active", item === active));
      };

      const grid = section.querySelector<HTMLElement>(".gallery-grid");
      grid?.addEventListener("pointermove", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const item = target.closest<HTMLElement>(".gallery-item");
        if (item) activateItem(item);
      }, { passive: true });

      items.forEach((item) => {
        const caption = item.querySelector<HTMLElement>(".gallery-item__caption");
        const show = () => {
          activateItem(item);
          if (caption) gsap.to(caption, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out", overwrite: "auto" });
        };

        item.addEventListener("mouseenter", show);
        item.addEventListener("focus", show);
        item.addEventListener("click", show);
        item.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          show();
        });
      });

      void ScrollTrigger;
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else {
      setup();
    }
  }
</script>

<style>
  .gallery-item {
    z-index: 1;
    transform-origin: center;
    transition:
      z-index 0s linear 0.18s,
      box-shadow 0.45s ease,
      filter 0.45s ease;
    will-change: transform, opacity;
  }

  .gallery-section {
    background:
      radial-gradient(circle at 14% 6%, rgba(184, 147, 90, 0.2), transparent 34rem),
      radial-gradient(circle at 82% 22%, rgba(143, 95, 61, 0.16), transparent 28rem),
      linear-gradient(180deg, #F4EFE6 0%, #EFE5D5 52%, #E9DDC9 100%);
  }

  .gallery-item.is-active {
    z-index: 1;
    transition-delay: 0s;
    box-shadow: 0 32px 90px rgba(10, 10, 10, 0.22);
  }

  .gallery-item:not(.is-active) {
    filter: saturate(0.86) brightness(0.92);
  }

  .gallery-item__reveal-cover {
    position: absolute;
    inset: 0;
    z-index: 20;
    pointer-events: none;
    background: #F4EFE6;
    clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
    will-change: clip-path;
  }

  .gallery-item__caption {
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.6);
    will-change: opacity, transform;
  }

  .gallery-item.is-active .gallery-item__caption {
    opacity: 1;
    transform: translateY(0);
  }

  @media (hover: hover) and (pointer: fine) {
    .gallery-grid:hover .gallery-item:not(:hover) {
      filter: saturate(0.78) brightness(0.84);
    }

    .gallery-item:hover,
    .gallery-item:focus-visible {
      z-index: 20;
      filter: saturate(1.04) brightness(1);
    }
  }

  @media (max-width: 767px) {
    #gallery {
      padding-block: 5.5rem;
    }

    .gallery-grid {
      gap: 1.4rem;
    }

    .gallery-item {
      border: 1px solid rgba(10, 10, 10, 0.1);
      background: rgba(255, 255, 255, 0.22);
      box-shadow: 0 20px 54px rgba(10, 10, 10, 0.12);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    .gallery-item__caption {
      left: 1rem;
      right: 1rem;
      bottom: 1rem;
      padding: 0.8rem 0.9rem;
      border: 1px solid rgba(244, 239, 230, 0.16);
      background: rgba(10, 10, 10, 0.38);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-item,
    .gallery-item__caption {
      transition: none;
    }
  }
</style>
