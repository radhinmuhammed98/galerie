---
import fr from '../i18n/fr.json';
import en from '../i18n/en.json';

const { lang } = Astro.props;
const t = lang === 'en' ? en : fr;
---

<section class="history-section py-32 px-6 md:px-12 text-noir-orfevre relative overflow-hidden" id="history">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 items-center">

    <div class="md:col-span-5 relative group history-img-container image-glide-left">
      <div class="aspect-[3/4] w-full overflow-hidden">
        <img
          src="/images/about/image_14.jpg"
          alt="Histoire de la galerie"
          class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 history-img"
          loading="lazy"
        />
      </div>
      <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b border-r border-or-fonce opacity-50"></div>
    </div>

    <div class="md:col-span-6 md:col-start-7 history-text-container">
      <h2 class="history-h2 text-4xl md:text-5xl font-serif mb-8 leading-tight">
        {t['history.h2']}
      </h2>
      <p class="history-paragraph font-sans text-lg leading-relaxed text-gray-700">
        {t['history.text']}
      </p>
    </div>

  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap-config";
  import { revealText } from "../lib/text-reveal";
  import { revealImage } from "../lib/image-reveal";

  if (typeof window !== "undefined") {
    const setup = () => {
      const section = document.getElementById("history");
      if (!section || section.dataset.historyBound === "true") return;
      section.dataset.historyBound = "true";

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // 1. Curtain reveal vertical sur l'image (descend de haut en bas)
      const imageFrame = section.querySelector<HTMLElement>(".history-img-container .aspect-\\[3\\/4\\]");
      const imageWrap = section.querySelector<HTMLElement>(".history-img-container");
      const img = section.querySelector<HTMLElement>(".history-img");
      if (imageWrap && !reduced) {
        gsap.fromTo(
          imageWrap,
          { x: -120, opacity: 0, rotate: -1.4, clipPath: "inset(0% 18% 0% 0%)" },
          {
            x: 0,
            opacity: 1,
            rotate: 0,
            clipPath: "inset(0% 0% 0% 0%)",
            duration: 1.25,
            ease: "power4.out",
            scrollTrigger: { trigger: section, start: "top 72%", once: true },
          }
        );

        gsap.to(imageWrap, {
          y: -34,
          ease: "none",
          scrollTrigger: { trigger: section, start: "top bottom", end: "bottom top", scrub: 1.2 },
        });
      }

      if (imageFrame && img) {
        revealImage(
          imageFrame,
          {
            direction: "curtain-top",
            duration: 1.4,
            coverColor: "#F4EFE6",
            scaleFrom: 1.04,
            scaleDuration: 1.6,
            scrollTrigger: { start: "top 75%", once: true },
          },
          img
        );
      }

      // 2. Split text H2 (mots, blur)
      const h2 = section.querySelector<HTMLElement>(".history-h2");
      if (h2) {
        revealText(h2, {
          mode: "words",
          stagger: 0.06,
          duration: 1.1,
          delay: 0.3,
          scrollTrigger: { start: "top 80%", once: true },
        });
      }

      // 3. Paragraphe : split par mots, plus rapide, encore plus subtil
      const p = section.querySelector<HTMLElement>(".history-paragraph");
      if (p) {
        revealText(p, {
          mode: "words",
          stagger: 0.025,
          duration: 0.8,
          yPercent: 60,
          blurPx: 6,
          delay: 0.5,
          scrollTrigger: { start: "top 80%", once: true },
        });
      }

      void ScrollTrigger;
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else {
      setup();
    }
  }
</script>

<style>
  .history-section {
    background:
      radial-gradient(circle at 18% 12%, rgba(184, 147, 90, 0.18), transparent 32rem),
      radial-gradient(circle at 84% 18%, rgba(143, 95, 61, 0.12), transparent 26rem),
      linear-gradient(180deg, #EFE5D5 0%, #F4EFE6 48%, #E9DDC9 100%);
  }

  .history-img-container {
    will-change: transform, opacity, clip-path;
  }

  .history-img-container .aspect-\[3\/4\] {
    box-shadow: 0 34px 100px rgba(10, 10, 10, 0.18);
  }

  @media (max-width: 767px) {
    .history-section {
      padding-block: 5.5rem;
    }

    .history-img-container .aspect-\[3\/4\] {
      border: 1px solid rgba(10, 10, 10, 0.1);
      box-shadow: 0 24px 68px rgba(10, 10, 10, 0.14);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .history-img-container {
      transform: none !important;
      opacity: 1 !important;
      clip-path: none !important;
    }
  }
</style>
