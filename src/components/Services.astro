---
import fr from '../i18n/fr.json';
import en from '../i18n/en.json';

const { lang } = Astro.props;
const t = lang === 'en' ? en : fr;

const services = [
  { id: 1, title: t['services.auctions'],    img: "/images/about/image_15.jpg" },
  { id: 2, title: t['services.consulting'],  img: "/images/about/image_16.jpg" },
  { id: 3, title: t['services.exhibitions'], img: "/images/about/image_17.jpg" }
];
---

<section class="py-32 surface-art text-ivoire relative overflow-hidden" id="services">
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <!-- Headline massif inspiré du site réel -->
    <div class="mb-20 overflow-hidden">
      <p class="services-label font-sans text-xs uppercase tracking-[0.3em] text-or-fonce mb-10 opacity-0">
        {lang === 'en' ? "What we offer" : "Nos expertises"}
      </p>
      <h2 class="services-headline font-sans font-bold uppercase leading-[0.88] tracking-tight text-ivoire"
          style="font-size: clamp(2.8rem, 8vw, 7.5rem);">
        {lang === 'en'
          ? <><span class="services-line block overflow-hidden"><span class="services-line-inner block" style="transform: translateY(105%);">Auctions</span></span><span class="services-line block overflow-hidden"><span class="services-line-inner block" style="transform: translateY(105%);">Expert Advice &</span></span><span class="services-line block overflow-hidden"><span class="services-line-inner block" style="transform: translateY(105%);">Curated Exhibitions</span></span></>
          : <><span class="services-line block overflow-hidden"><span class="services-line-inner block" style="transform: translateY(105%);">Ventes aux Enchères</span></span><span class="services-line block overflow-hidden"><span class="services-line-inner block" style="transform: translateY(105%);">Conseils d'Experts &</span></span><span class="services-line block overflow-hidden"><span class="services-line-inner block" style="transform: translateY(105%);">Expositions Organisées</span></span></>
        }
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((svc) => (
        <a
          href="#contact-cta"
          data-scroll-link
          class="service-card relative group aspect-[3/4] overflow-hidden cursor-pointer"
          data-cursor="link"
          data-magnetic
          data-magnetic-radius="120"
          data-magnetic-amp="14"
          data-magnetic-inner=".service-card__title-wrap"
          data-magnetic-inner-amp="6"
        >
          <div class="absolute inset-0 z-0">
            <img src={svc.img} alt={svc.title} class="service-card__img w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-110 transition-all duration-700 ease-out" loading="lazy" />
          </div>

          <div class="absolute inset-0 z-10 flex flex-col justify-end p-8 bg-gradient-to-t from-noir-orfevre/90 to-transparent">
            <div class="service-card__title-wrap">
              <h3 class="text-2xl font-serif text-or-clair transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                {svc.title}
              </h3>
              <div class="w-12 h-px bg-or-fonce mt-6 transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500 delay-100"></div>
              <span class="service-card__cta mt-5 inline-flex items-center gap-3 font-sans text-[10px] uppercase tracking-[0.22em] text-ivoire/80">
                {lang === 'en' ? 'Enquire' : 'Demander'}
                <span aria-hidden="true">+</span>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap-config";

  if (typeof window !== "undefined") {
    const setup = () => {
      const section = document.getElementById("services");
      if (!section) return;
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (reduced) {
        section.querySelectorAll<HTMLElement>(".services-line-inner, .services-label").forEach(el => {
          el.style.transform = "none"; el.style.opacity = "1";
        });
      } else {
        // Label fade-in
        const label = section.querySelector<HTMLElement>(".services-label");
        if (label) {
          gsap.to(label, { opacity: 1, duration: 0.7, ease: "power3.out",
            scrollTrigger: { trigger: section, start: "top 80%", once: true } });
        }

        // Headline : chaque ligne remonte depuis le bas (masquée par overflow-hidden)
        const lineInners = section.querySelectorAll<HTMLElement>(".services-line-inner");
        lineInners.forEach((el, i) => {
          gsap.to(el, {
            y: "0%", duration: 1.1, ease: "power4.out",
            delay: i * 0.12,
            scrollTrigger: { trigger: section, start: "top 78%", once: true },
          });
        });
      }

      // Cards reveal : leger decalage vertical + profondeur pour garder le rythme editorial.
      gsap.fromTo(".service-card",
        { y: 90, opacity: 0, rotateX: 5 },
        {
          y: 0, opacity: 1, rotateX: 0, duration: 1.05, stagger: 0.18, ease: "power3.out",
          scrollTrigger: { trigger: "#services", start: "top 70%" }
        }
      );
      void ScrollTrigger;
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else {
      setup();
    }
  }
</script>

<style>
  .service-card__title-wrap { will-change: transform; }
  .services-line-inner { will-change: transform; }
  .service-card {
    isolation: isolate;
    transform-style: preserve-3d;
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.18);
  }
  .service-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    background:
      radial-gradient(circle at 50% 0%, rgba(212, 184, 134, 0.24), transparent 42%),
      linear-gradient(135deg, rgba(244, 239, 230, 0.12), transparent 38%);
    mix-blend-mode: screen;
    transition: opacity 0.55s ease;
  }
  .service-card:hover::after,
  .service-card:focus-visible::after {
    opacity: 1;
  }
  .service-card__cta {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  .service-card:hover .service-card__cta,
  .service-card:focus-visible .service-card__cta {
    opacity: 1;
    transform: translateY(0);
  }
  @media (max-width: 767px) {
    #services {
      padding-block: 5.5rem;
    }

    .service-card {
      min-height: 58vh;
      border: 1px solid rgba(244, 239, 230, 0.12);
      background: rgba(244, 239, 230, 0.04);
      box-shadow: 0 22px 60px rgba(0, 0, 0, 0.28);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    .service-card__title-wrap {
      padding: 0.85rem;
      border: 1px solid rgba(212, 184, 134, 0.16);
      background: rgba(10, 10, 10, 0.34);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .services-line-inner { transform: none !important; }
  }
</style>
