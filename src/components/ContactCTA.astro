---
// Section CTA Contact — reprend le style "NOUS CONTACTER" du site réel
// avec fond noir, typographie bold, et bouton "Nous écrire" magnétique.

import fr from '../i18n/fr.json';
import en from '../i18n/en.json';

const { lang } = Astro.props;
const t = lang === 'en' ? en : fr;

const ctaTitle = lang === 'en' ? "Contact us" : "Nous contacter";
const ctaButton = lang === 'en' ? "Write to us" : "Nous écrire";
const ctaSub = lang === 'en'
  ? "A question about a work, an auction, or an upcoming exhibition? We respond within 24 hours."
  : "Une question sur une œuvre, une vente aux enchères, ou une prochaine exposition ? Nous répondons sous 24h.";

const contactPath = lang === 'en' ? '/en/contact' : '/fr/contact';
---

<section
  class="contact-cta-section relative bg-noir-orfevre text-ivoire overflow-hidden"
  id="contact-cta"
  aria-label={ctaTitle}
>

  <!-- Ligne décorative top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-or-fonce/50 to-transparent"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 py-32 md:py-40">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-end">

      <!-- Titre massif -->
      <div>
        <p class="cta-label font-sans text-xs uppercase tracking-[0.3em] text-or-fonce mb-8 opacity-0">
          {lang === 'en' ? "Get in touch" : "Prendre contact"}
        </p>
        <h2 class="cta-title font-serif text-[clamp(3.5rem,9vw,8rem)] leading-[0.9] tracking-tight uppercase text-ivoire">
          {ctaTitle.split(' ').map((word) => (
            <span class="cta-title-word block overflow-hidden">
              <span class="cta-title-inner inline-block" style="transform: translateY(105%);">{word}</span>
            </span>
          ))}
        </h2>
      </div>

      <!-- Colonne droite : sous-texte + bouton + infos -->
      <div class="cta-right flex flex-col gap-8 opacity-0" style="transform: translateY(24px);">
        <p class="font-sans text-base md:text-lg text-gray-400 leading-relaxed max-w-md">
          {ctaSub}
        </p>

        <!-- Bouton principal -->
        <div>
          <a
            href={`mailto:${t['footer.email']}`}
            class="cta-btn group relative inline-flex items-center gap-4 font-sans text-sm uppercase tracking-[0.2em] text-noir-orfevre bg-ivoire px-8 py-5 overflow-hidden transition-colors duration-500 hover:text-ivoire"
            data-cursor="link"
            data-magnetic
            data-magnetic-radius="80"
            data-magnetic-amp="12"
          >
            <!-- Fond or qui remonte au hover -->
            <span class="cta-btn-bg absolute inset-0 bg-or-fonce translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></span>
            <span class="relative z-10">{ctaButton}</span>
            <!-- Flèche →  -->
            <svg class="relative z-10 w-4 h-4 transition-transform duration-500 group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Infos pratiques en grille -->
        <dl class="grid grid-cols-2 gap-6 pt-6 border-t border-gris-pierre/60 font-sans text-sm">
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] text-or-fonce mb-1">{lang === 'en' ? "Address" : "Adresse"}</dt>
            <dd class="text-gray-300">
              <a
                href="https://maps.app.goo.gl/ujnrZnnR2cDhBdiDA"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-or-fonce transition-colors"
              >
                23 Place Dauphine<br/>Paris 1<sup>er</sup>
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] text-or-fonce mb-1">{lang === 'en' ? "Hours" : "Horaires"}</dt>
            <dd class="text-gray-300">{t['footer.hours']}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] text-or-fonce mb-1">Email</dt>
            <dd>
              <a href={`mailto:${t['footer.email']}`} class="text-gray-300 hover:text-or-fonce transition-colors">
                {t['footer.email']}
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] text-or-fonce mb-1">Social</dt>
            <dd class="flex flex-col gap-1">
              <a href="https://instagram.com/orfevres_galerie" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-or-fonce transition-colors">Instagram</a>
              <a href="https://linkedin.com/company/galeriedesorfeveres" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-or-fonce transition-colors">LinkedIn</a>
            </dd>
          </div>
        </dl>
      </div>

    </div>
  </div>

  <!-- Grain texture overlay subtil -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22 opacity=%221%22/%3E%3C/svg%3E'); background-size: 200px 200px;"></div>

</section>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap-config";

  if (typeof window !== "undefined") {
    const setup = () => {
      const section = document.getElementById("contact-cta");
      if (!section) return;
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduced) {
        section.querySelectorAll<HTMLElement>(".cta-label, .cta-right, .cta-title-inner").forEach(el => {
          el.style.opacity = "1";
          el.style.transform = "none";
        });
        return;
      }

      const tl = gsap.timeline({
        scrollTrigger: { trigger: section, start: "top 70%", once: true },
      });

      // Label
      const label = section.querySelector<HTMLElement>(".cta-label");
      if (label) tl.to(label, { opacity: 1, duration: 0.7, ease: "power3.out" });

      // Titre : chaque mot remonte depuis le bas (masqué par overflow-hidden)
      const titleInners = section.querySelectorAll<HTMLElement>(".cta-title-inner");
      titleInners.forEach((el, i) => {
        tl.to(el, { y: "0%", duration: 1, ease: "power4.out" }, i === 0 ? "-=0.3" : "-=0.7");
      });

      // Colonne droite
      const right = section.querySelector<HTMLElement>(".cta-right");
      if (right) tl.to(right, { opacity: 1, y: 0, duration: 1, ease: "power3.out" }, "-=0.5");

      void ScrollTrigger;
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup, { once: true });
    } else {
      setup();
    }
  }
</script>

<style>
  .cta-title-word { line-height: 1.05; }
  .cta-title-inner { will-change: transform; }
  .cta-btn-bg { will-change: transform; }
  .cta-btn { will-change: color; }

  @media (prefers-reduced-motion: reduce) {
    .cta-title-inner { transform: none !important; }
  }
</style>
